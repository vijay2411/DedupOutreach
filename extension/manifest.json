{
  "manifest_version": 3,
  "name": "DedupManager",
  "version": "0.1.0",
  "description": "Shared cold-outreach dedup: auto-detects who you're viewing on LinkedIn / Reddit / Gmail and warns if a teammate already approached them.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.reddit.com/*",
    "https://mail.google.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "DedupManager" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["matcher.js", "content.js"],
      "css": ["badge.css"],
      "run_at": "document_idle"
    }
  ]
}
